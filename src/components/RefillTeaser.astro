---
import { RefreshCw, ArrowRight } from 'lucide-react';
import { SAVINGS_AMOUNT } from '../lib/data.js';
---

<section class="py-20 bg-jesmac-blue">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 text-jesmac-lemon text-sm font-bold mb-6">
      <RefreshCw size={16} /> Already have a bottle?
    </div>
    <h2 class="text-3xl sm:text-5xl font-bold text-white mb-4">Refill & Save ₦{SAVINGS_AMOUNT}</h2>
    <p class="text-blue-100 text-lg max-w-xl mx-auto mb-8">
      Keep your bottle. Top it up. Same powerful formula, less waste, more money in your pocket.
    </p>
    <a href="/shop" class="inline-flex items-center gap-2 bg-white text-jesmac-blue px-8 py-3 rounded-full font-bold hover:bg-jesmac-lemon hover:text-jesmac-lemon-dark transition-colors">
      Order Refill <ArrowRight size={18} />
    </a>
  </div>
</section>

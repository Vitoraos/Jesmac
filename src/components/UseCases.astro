---
import { Utensils, Shirt, Car } from 'lucide-react';
import { USE_CASES } from '../lib/data.js';

const iconMap = {
  Utensils: Utensils,
  Shirt: Shirt,
  Car: Car,
};
---

<section class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-3">One Soap. Every Mess.</h2>
      <p class="text-slate-600 max-w-xl mx-auto">Why buy three different cleaners? Jesmac handles the whole house.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {USE_CASES.map((use) => {
        const Icon = iconMap[use.icon];
        return (
          <div class="group p-8 rounded-2xl bg-slate-50 border border-slate-100 hover:border-jesmac-blue/20 hover:shadow-lg transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-jesmac-blue-light text-jesmac-blue flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
              <Icon size={24} />
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">{use.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{use.desc}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>

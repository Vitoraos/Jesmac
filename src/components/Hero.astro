---
import { ArrowRight, Droplets } from 'lucide-react';
---

<section class="relative min-h-screen flex items-center pt-16 overflow-hidden bg-gradient-to-br from-slate-50 via-white to-jesmac-blue-light">
  {/* Animated bubbles — pure CSS, zero JS */}
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    {[...Array(12)].map((_, i) => (
      <div
        class="absolute rounded-full opacity-20"
        style={{
          left: `${8 + (i * 7) % 84}%`,
          width: `${20 + (i * 13) % 45}px`,
          height: `${20 + (i * 13) % 45}px`,
          background: i % 3 === 0 ? '#FFD60A' : i % 2 === 0 ? '#0066CC' : '#00A896',
          animation: `bubbleRise ${5 + (i % 4)}s linear infinite`,
          animationDelay: `${i * 0.4}s`,
          bottom: '-50px',
        }}
      />
    ))}
  </div>

  <style>
    @keyframes bubbleRise {
      0% { transform: translateY(0) scale(0.8); opacity: 0; }
      10% { opacity: 0.5; }
      90% { opacity: 0.5; }
      100% { transform: translateY(-110vh) scale(1.2); opacity: 0; }
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-12px); }
    }
    @keyframes floatDelayed {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }
    .animate-float { animation: float 4s ease-in-out infinite; }
    .animate-float-delayed { animation: floatDelayed 4s ease-in-out 2s infinite; }
  </style>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 py-20 grid lg:grid-cols-2 gap-12 items-center">
    <div class="space-y-6">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-jesmac-blue-light text-jesmac-blue text-xs font-bold uppercase tracking-wider">
        <Droplets size={14} /> 75cl Multi-Purpose Liquid Soap
      </div>
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-slate-900 leading-[1.1]">
        Tough on Dirt. <span class="text-jesmac-blue">Everywhere.</span>
      </h1>
      <p class="text-lg text-slate-600 max-w-md leading-relaxed">
        One powerful formula for plates, fabrics, and vehicles. No fluff. No nonsense. Just deep cleaning power in a 75cl bottle.
      </p>
      <div class="flex flex-wrap gap-4 pt-2">
        <a href="/shop" class="btn-primary">
          Shop Now <ArrowRight size={18} />
        </a>
        <a href="/shop" class="btn-lemon">View Refills</a>
      </div>
      <div class="flex items-center gap-6 pt-4 text-sm text-slate-500">
        <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-jesmac-teal"></span>2 Scents</span>
        <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-jesmac-lemon"></span>75cl Size</span>
        <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-jesmac-blue"></span>WhatsApp Delivery</span>
      </div>
    </div>

    {/* CSS Bottles */}
    <div class="relative flex justify-center items-center gap-6 lg:gap-10">
      <div class="animate-float relative">
        <div class="w-32 h-56 sm:w-40 sm:h-72 rounded-3xl bg-gradient-to-b from-yellow-300 to-yellow-400 shadow-2xl border border-yellow-200 flex flex-col items-center justify-end pb-4 relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1/3 bg-white/30 rounded-t-3xl"></div>
          <div class="absolute top-4 w-16 h-4 bg-white/60 rounded-full"></div>
          <span class="relative z-10 text-2xl font-bold text-yellow-900">Lemon</span>
          <span class="relative z-10 text-xs font-semibold text-yellow-800">75cl</span>
        </div>
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-10 h-6 bg-yellow-500 rounded-t-lg"></div>
      </div>

      <div class="animate-float-delayed relative mt-12">
        <div class="w-32 h-56 sm:w-40 sm:h-72 rounded-3xl bg-gradient-to-b from-teal-400 to-teal-600 shadow-2xl border border-teal-300 flex flex-col items-center justify-end pb-4 relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1/3 bg-white/20 rounded-t-3xl"></div>
          <div class="absolute top-4 w-16 h-4 bg-white/50 rounded-full"></div>
          <span class="relative z-10 text-2xl font-bold text-white">Green</span>
          <span class="relative z-10 text-xs font-semibold text-teal-100">75cl</span>
        </div>
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-10 h-6 bg-teal-600 rounded-t-lg"></div>
      </div>
    </div>
  </div>
</section>
